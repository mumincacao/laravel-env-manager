{
    "name": "mumincacao/laravel-env-manager",
    "description": "Encrypted environment variable manager for Laravel.",
    "type": "library",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "larastan/larastan": "^3.10",
        "nunomaduro/phpinsights": "^2.14",
        "brianium/paratest": "^7.20",
        "mockery/mockery": "^1.6"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Mumincacao\\LaravelEnvManager\\": "src/",
            "Mumincacao\\LaravelEnvManager\\tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Mumin Cacao",
            "email": "mumincacao@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Mumincacao\\LaravelEnvManager\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": [
            "@php vendor/bin/phpinsights --no-interaction",
            "@php vendor/bin/phpstan analyze --level 5 src/ tests/",
            "XDEBUG_MODE=coverage php vendor/bin/phpunit --coverage-text"
        ],
        "coverage": [
            "XDEBUG_MODE=coverage php vendor/bin/paratest --coverage-html=coverage"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    }
}
